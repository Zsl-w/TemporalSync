{
  "entities": {
    "LearningRecord": {
      "title": "Learning Record",
      "description": "Represents a learning session or milestone.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the learning content" },
        "links": { "type": "array", "items": { "type": "string" }, "description": "Reference links (videos, blogs, etc.)" },
        "category": { "type": "string", "description": "Category (AI, Development, etc.)" },
        "status": { "type": "string", "enum": ["已完成", "进行中", "待开始"], "description": "Completion status" },
        "userId": { "type": "string", "description": "ID of the user who owns this record" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "category", "status", "userId", "createdAt"]
    },
    "PublishingPlan": {
      "title": "Publishing Plan",
      "description": "Represents a scheduled content post with performance metrics.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the post" },
        "platform": { "type": "string", "description": "Target platform (WeChat, XHS, etc.)" },
        "date": { "type": "string", "description": "Target publication date/time string" },
        "status": { "type": "string", "enum": ["就绪", "审核中", "草稿", "已发布"], "description": "Publishing status" },
        "stats": {
          "type": "object",
          "properties": {
            "views": { "type": "number", "default": 0 },
            "likes": { "type": "number", "default": 0 },
            "comments": { "type": "number", "default": 0 },
            "bookmarks": { "type": "number", "default": 0 },
            "shares": { "type": "number", "default": 0 }
          }
        },
        "color": { "type": "string", "description": "UI accent color class" },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        },
        "notes": { "type": "string", "description": "Collaboration notes or feedback" },
        "userId": { "type": "string", "description": "ID of the user who owns this plan" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "platform", "status", "userId", "createdAt"]
    },
    "PlatformStats": {
      "title": "Platform Stats",
      "description": "History of follower counts for different platforms.",
      "type": "object",
      "properties": {
        "platform": { "type": "string", "enum": ["WeChat", "XHS"] },
        "followers": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["platform", "followers", "userId", "createdAt"]
    },
    "Link": {
      "title": "Link",
      "description": "Represents a saved bookmark.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the link" },
        "domain": { "type": "string", "description": "Domain name" },
        "url": { "type": "string", "description": "Full URL" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for categorization" },
        "userId": { "type": "string", "description": "ID of the user who owns this link" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "url", "userId", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Custom category for learning records.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the category" },
        "color": { "type": "string", "description": "Hex color or class name for the category" },
        "userId": { "type": "string", "description": "ID of the user who owns this category" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "userId", "createdAt"]
    }
  },
  "firestore": {
    "learning_records": {
      "schema": "LearningRecord",
      "description": "Collection of learning achievements and logs."
    },
    "publishing_plans": {
      "schema": "PublishingPlan",
      "description": "Collection of scheduled content posts."
    },
    "platform_stats": {
      "schema": "PlatformStats",
      "description": "History of follower metrics for each platform."
    },
    "links": {
      "schema": "Link",
      "description": "Collection of saved digital resources and links."
    },
    "categories": {
      "schema": "Category",
      "description": "User defined categories for better organization."
    }
  }
}
