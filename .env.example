# CloudBase 环境 ID
VITE_CLOUDBASE_ENV_ID=your-env-id

# CloudBase 区域
VITE_CLOUDBASE_REGION=ap-shanghai

# CloudBase Publishable Key (从控制台获取: https://tcb.cloud.tencent.com/dev?envId={envId}#/env/apikey)
VITE_CLOUDBASE_ACCESS_KEY=your-publishable-key

# Xiaomi MiMo pay-as-you-go API. Use an sk- key, not a Token Plan tp- key.
MIMO_API_KEY="MY_MIMO_API_KEY"
MIMO_BASE_URL="https://api.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2.5-pro"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
