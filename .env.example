# CloudBase 环境 ID
VITE_CLOUDBASE_ENV_ID=your-env-id

# CloudBase 区域
VITE_CLOUDBASE_REGION=ap-shanghai

# CloudBase Publishable Key (从控制台获取: https://tcb.cloud.tencent.com/dev?envId={envId}#/env/apikey)
VITE_CLOUDBASE_ACCESS_KEY=your-publishable-key

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# 服务端 AI 新闻增强。不要添加 VITE_ 前缀。
MIMO_API_KEY="sk-替换为你的密钥"
MIMO_BASE_URL="https://api.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2"
