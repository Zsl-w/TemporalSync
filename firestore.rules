rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'wangzouszz@gmail.com';
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------

    function isValidLearningRecord(data) {
      return data.keys().hasAll(['title', 'category', 'status', 'userId', 'createdAt'])
        && data.keys().size() <= 6 // title, links, category, status, userId, createdAt
        && data.title is string && data.title.size() <= 200
        && data.category is string && data.category.size() <= 50
        && data.status in ['已完成', '进行中', '待开始']
        && data.userId == request.auth.uid
        && (data.get('links', []) is list && data.get('links', []).size() <= 10);
    }

    function isValidPublishingPlan(data, isUpdate) {
      let keys = data.keys();
      return (isUpdate ? true : keys.hasAll(['title', 'platform', 'status', 'userId', 'createdAt']))
        && keys.size() <= 15
        && (!keys.contains('title') || (data.title is string && data.title.size() <= 200))
        && (!keys.contains('platform') || (data.platform is string && data.platform.size() <= 50))
        && (!keys.contains('status') || (data.status in ['就绪', '审核中', '草稿', '已发布']))
        && (!keys.contains('userId') || (data.userId == request.auth.uid))
        && (!keys.contains('date') || (data.date is string && data.date.size() <= 100))
        && (!keys.contains('color') || (data.color is string && data.color.size() <= 50))
        && (!keys.contains('notes') || (data.notes is string && data.notes.size() <= 5000))
        && (!keys.contains('checklist') || (data.checklist is list && data.checklist.size() <= 20))
        && (!keys.contains('stats') || (
             data.stats is map 
             && data.stats.get('views', 0) is number 
             && data.stats.get('likes', 0) is number
             && data.stats.get('comments', 0) is number
             && data.stats.get('bookmarks', 0) is number
             && data.stats.get('shares', 0) is number
           ));
    }

    function isValidPlatformStats(data) {
      return data.keys().hasAll(['platform', 'followers', 'userId', 'createdAt'])
        && data.keys().size() == 4
        && data.platform in ['WeChat', 'XHS']
        && data.followers is number
        && data.userId == request.auth.uid;
    }

    function isValidLink(data) {
      return data.keys().hasAll(['title', 'url', 'userId', 'createdAt'])
        && data.keys().size() <= 10
        && data.title is string && data.title.size() <= 200
        && data.url is string && data.url.size() <= 2048
        && data.userId == request.auth.uid
        && (data.get('domain', '') is string && data.get('domain', '').size() <= 100)
        && (data.get('tags', []) is list && data.get('tags', []).size() <= 10);
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'userId', 'createdAt'])
        && data.keys().size() <= 6
        && data.name is string && data.name.size() <= 50
        && data.userId == request.auth.uid
        && (data.get('color', '') is string && data.get('color', '').size() <= 50);
    }

    // -------------------------------------------------------------------------
    // DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    match /learning_records/{recordId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(recordId) && isValidLearningRecord(incoming()) 
                     && incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) && isValidLearningRecord(incoming())
                     && incoming().userId == existing().userId
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing().userId);
    }

    match /publishing_plans/{planId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(planId) && isValidPublishingPlan(incoming(), false)
                     && incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) && (
        // Action: Status Toggle
        (incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status in ['就绪', '审核中', '草稿', '已发布']) ||
        // Action: Stats Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['stats']) && 
           incoming().stats is map && 
           incoming().stats.get('views', 0) is number) ||
        // Full Update
        isValidPublishingPlan(incoming(), true)
      ) && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing().userId);
    }

    match /platform_stats/{statId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(statId) && isValidPlatformStats(incoming())
                     && incoming().createdAt == request.time;
      allow delete: if isOwner(existing().userId);
    }

    match /links/{linkId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(linkId) && isValidLink(incoming())
                     && incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) && isValidLink(incoming())
                     && incoming().userId == existing().userId
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing().userId);
    }

    match /categories/{categoryId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(categoryId) && isValidCategory(incoming())
                     && incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) && isValidCategory(incoming())
                     && incoming().userId == existing().userId
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing().userId);
    }

    match /blogs/{blogId} {
      allow get, list: if true;
      allow create: if isAdmin() && incoming().userId == request.auth.uid 
                     && incoming().createdAt == request.time;
      allow update: if isAdmin() && incoming().userId == existing().userId
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }
  }
}
